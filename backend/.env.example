# ── Application ─────────────────────────────────────────────
APP_NAME="Healthcare Copilot API"
APP_ENV=development
APP_DEBUG=true
API_PREFIX=/api/v1
SECRET_KEY=supersecretkey-change-in-production-must-be-32chars

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=healthcopilot
POSTGRES_USER=hc_user
POSTGRES_PASSWORD=changeme

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
SESSION_TTL_SECONDS=86400

# ── ChromaDB ─────────────────────────────────────────────────
CHROMADB_HOST=localhost
CHROMADB_PORT=8000
CHROMADB_COLLECTION=healthcare_schema
# Options: "http" (Docker/server), "ephemeral" (in-process, no Docker needed), "persistent" (local file)
CHROMADB_MODE=ephemeral

# ── LLM (vLLM / Ollama — OpenAI-compatible) ──────────────────
LLM_BASE_URL=http://localhost:8080/v1
LLM_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
LLM_API_KEY=not-needed-for-local
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.1
LLM_TIMEOUT_SECONDS=60

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Query Execution ──────────────────────────────────────────
QUERY_TIMEOUT_SECONDS=30
MAX_ROWS=10000

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Embeddings ───────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_TOP_K=5
